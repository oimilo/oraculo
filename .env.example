# O Oraculo - Environment Configuration
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ============================================
# Service Toggle
# ============================================
# Set to "true" to use real API services instead of mocks
# When "false" or unset, the app uses mock services (no API keys needed)
NEXT_PUBLIC_USE_REAL_APIS=false

# ============================================
# ElevenLabs - Text-to-Speech
# ============================================
# Get your API key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice ID for the Oracle character
# Default: Rachel (21m00Tcm4TlvDq8ikWAM) - change to your cloned voice
# Find voice IDs at: https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ElevenLabs Model Version Toggle
# Set to "true" to use eleven_v3 model (audio tags, no SSML)
# Set to "false" or leave unset for eleven_multilingual_v2 (SSML breaks)
# NOTE: Voice must be IVC (Instant Voice Clone) for v3 audio tag support
USE_V3_MODEL=false

# ============================================
# OpenAI - Speech-to-Text (Whisper)
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Anthropic - Natural Language Understanding (Claude)
# ============================================
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# Supabase - Analytics (Phase 6)
# ============================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
